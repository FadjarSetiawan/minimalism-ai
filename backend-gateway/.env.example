# Minimalism AI - Backend Gateway Environment Template
PORT=3000

# -----------------------------------------------------------------------------
# 1. CORE INTEL: GEMINI API KEY
# -----------------------------------------------------------------------------
# Put your Google AI Studio Gemini API Key here to enable live LLM generations.
# If left empty, the high-fidelity built-in skills simulator will take over!
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# 2. DATABASE & AUTH: SUPABASE (OPTIONAL)
# -----------------------------------------------------------------------------
# Fill these to connect to a live Supabase PostgreSQL server.
# If empty, the backend falls back to a stateful in-memory mock database.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# 3. PAYMENT: TRIPAY QRIS MERCHANT (OPTIONAL)
# -----------------------------------------------------------------------------
# Fill these to configure live Tripay QRIS payment integrations.
# If empty, the built-in local scanning simulation panel remains active.
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
